# IBM ELM credentials.
# Copy this file to .env and fill in your values. NEVER commit .env to git.
#
# One login works across all five ELM domains: DNG (Requirements),
# EWM (Work Items, SCM, Code Reviews), ETM (Test Management),
# GCM (Global Configuration), and JTS (Jazz Team Server).
#
# URL accepts any of these formats — the client extracts the server root
# and re-attaches each domain path explicitly:
#   https://yourcompany.elm.ibmcloud.com
#   https://yourcompany.elm.ibmcloud.com/rm
#   https://yourcompany.elm.ibmcloud.com/ccm
#   https://yourcompany.elm.ibmcloud.com/jts
#
# Legacy DOORS_URL / DOORS_USERNAME / DOORS_PASSWORD are still read
# (lower priority) so older setups keep working.

ELM_URL=https://your-elm-server.com
ELM_USERNAME=your_username
ELM_PASSWORD=your_password
